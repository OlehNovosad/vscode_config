{
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                        🎨 APPEARANCE & THEME                             ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "workbench.iconTheme": "vscode-icons",
    "workbench.startupEditor": "none",
    "workbench.tree.indent": 16,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.labelFormat": "short",
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                        ✏️ EDITOR CORE SETTINGS                           ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    // 🔤 Typography
    "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'SF Mono', 'Cascadia Code', Consolas, monospace",
    "editor.fontSize": 13,
    "editor.fontLigatures": true,
    "editor.lineHeight": 22,
    "editor.letterSpacing": 0.5,
    "editor.fontWeight": "400",
    // 🖱️ Cursor & Navigation
    "editor.cursorBlinking": "phase",
    "editor.cursorStyle": "line",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.scrollBeyondLastLine": true,
    "editor.mouseWheelZoom": true,
    "editor.stickyScroll.enabled": true,
    // 📐 Indentation & Whitespace
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.renderWhitespace": "selection",
    "editor.trimAutoWhitespace": true,
    // 🌈 Visual Enhancements
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.guides.indentation": true,
    "editor.guides.highlightActiveIndentation": true,
    "editor.renderLineHighlight": "all",
    "editor.minimap.enabled": true,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.maxColumn": 80,
    // 📍 Breadcrumbs & Navigation
    "breadcrumbs.enabled": true,
    "breadcrumbs.filePath": "on",
    "breadcrumbs.symbolPath": "on",
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                       💡 INTELLISENSE & SUGGESTIONS                      ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "editor.suggestSelection": "first",
    "editor.snippetSuggestions": "inline",
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": true
    },
    "editor.acceptSuggestionOnEnter": "on",
    "editor.wordBasedSuggestions": "matchingDocuments",
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggest.showStatusBar": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.enabled": true,
    "editor.inlayHints.enabled": "on",
    "editor.parameterHints.enabled": true,
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                        💾 FILE & AUTO-SAVE                               ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/.cache": true,
        "**/.git": true,
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/build": false
    },
    "files.watcherExclude": {
        "**/build/**": true,
        "**/.git/objects/**": true,
        "**/node_modules/**": true
    },
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                       🔧 CODE ACTIONS & FORMATTING                       ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "editor.formatOnSave": false,
    "editor.formatOnType": true,
    "editor.formatOnPaste": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "explicit"
    },
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                        📁 EXPLORER & FILE NESTING                        ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.sortOrder": "type",
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        // C/C++ patterns
        "*.cpp": "${capture}.h, ${capture}.hpp, ${capture}.tpp, ${capture}.inl",
        "*.c": "${capture}.h",
        "*.h": "${capture}.cpp, ${capture}.c",
        // CMake patterns
        "CMakeLists.txt": "CMakePresets.json, CMakeUserPresets.json, cmake-variants.yaml, .clang-format, .clang-tidy, compile_commands.json",
        // Python patterns
        "*.py": "${capture}.pyi, ${capture}_test.py, test_${capture}.py",
        // Package patterns
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, .npmrc, .nvmrc",
        // Config patterns
        ".gitignore": ".gitattributes, .gitmodules, .mailmap",
        "Makefile": "*.mk, makefile, GNUmakefile"
    },
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                           🐍 PYTHON                                      ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": false,
        "editor.tabSize": 4,
        "editor.rulers": [
            88,
            120
        ],
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit",
            "source.fixAll": "explicit"
        },
        "editor.semanticHighlighting.enabled": true
    },
    // Pylance Language Server
    "python.languageServer": "Pylance",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.autoSearchPaths": true,
    "python.analysis.indexing": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.callArgumentNames": "partial",
    "python.analysis.inlayHints.pytestParameters": true,
    "python.analysis.diagnosticSeverityOverrides": {
        "reportUnusedImport": "information",
        "reportUnusedVariable": "information",
        "reportGeneralTypeIssues": "warning"
    },
    "python.terminal.activateEnvironment": true,
    "python.experiments.enabled": false,
    // Ruff (Blazing Fast Linter & Formatter)
    "ruff.enable": true,
    "ruff.organizeImports": true,
    "ruff.fixAll": true,
    "ruff.lint.enable": true,
    "ruff.nativeServer": "on",
    "ruff.configuration": {
        "line-length": 88,
        "select": [
            "E",
            "F",
            "W",
            "I",
            "N",
            "UP",
            "B",
            "A",
            "C4",
            "SIM",
            "RET",
            "PTH",
            "ERA"
        ]
    },
    // Testing
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                          ⚡ C/C++ EMBEDDED                               ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": false,
        "editor.tabSize": 4,
        "editor.rulers": [
            80,
            120
        ],
        "editor.semanticHighlighting.enabled": true
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": false,
        "editor.tabSize": 4,
        "editor.rulers": [
            80,
            120
        ],
        "editor.semanticHighlighting.enabled": true
    },
    // C/C++ Extension
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.autocomplete": "default",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.formatting": "clangFormat",
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: LLVM, IndentWidth: 4, UseTab: Never, ColumnLimit: 0, AllowShortFunctionsOnASingleLine: All, BinPackArguments: true, BinPackParameters: true, AllowAllArgumentsOnNextLine: true, AllowAllParametersOfDeclarationOnNextLine: true }",
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.default.compilerPath": "",
    "C_Cpp.inlayHints.enabled": true,
    "C_Cpp.inlayHints.parameterNames.enabled": false,
    // Clangd
    "clangd.detectExtensionConflicts": false,
    // CMake Tools
    "cmake.configureOnOpen": true,
    "cmake.buildBeforeRun": true,
    "cmake.clearOutputBeforeBuild": true,
    "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
    "cmake.configureSettings": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
    },
    "cmake.generator": "Ninja",
    "cmake.showOptionsMovedNotification": false,
    // Makefile
    "makefile.configureOnOpen": true,
    "[makefile]": {
        "editor.insertSpaces": false,
        "editor.tabSize": 4,
        "editor.renderWhitespace": "all",
        "editor.formatOnSave": false,
        "editor.acceptSuggestionOnEnter": "off",
        "files.trimTrailingWhitespace": true
    },
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                          🦀 RUST                                         ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": false,
        "editor.tabSize": 4,
        "editor.rulers": [
            100
        ],
        "editor.semanticHighlighting.enabled": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    // Rust Analyzer (rust-lang.rust-analyzer)
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.checkOnSave": true,
    "rust-analyzer.cargo.buildScripts.enable": true,
    "rust-analyzer.cargo.autoreload": true,
    "rust-analyzer.procMacro.enable": true,
    "rust-analyzer.completion.autoimport.enable": true,
    "rust-analyzer.completion.postfix.enable": true,
    "rust-analyzer.completion.snippets.custom": {
        "Arc::new": {
            "postfix": "arc",
            "body": "Arc::new(${receiver})",
            "requires": "std::sync::Arc",
            "scope": "expr"
        },
        "Rc::new": {
            "postfix": "rc",
            "body": "Rc::new(${receiver})",
            "requires": "std::rc::Rc",
            "scope": "expr"
        },
        "Box::pin": {
            "postfix": "pinbox",
            "body": "Box::pin(${receiver})",
            "requires": "std::boxed::Box",
            "scope": "expr"
        }
    },
    "rust-analyzer.hover.actions.enable": true,
    "rust-analyzer.hover.actions.references.enable": true,
    "rust-analyzer.hover.actions.run.enable": true,
    "rust-analyzer.hover.actions.debug.enable": true,
    "rust-analyzer.hover.documentation.enable": true,
    "rust-analyzer.inlayHints.bindingModeHints.enable": true,
    "rust-analyzer.inlayHints.chainingHints.enable": true,
    "rust-analyzer.inlayHints.closingBraceHints.enable": true,
    "rust-analyzer.inlayHints.closureReturnTypeHints.enable": "with_block",
    "rust-analyzer.inlayHints.lifetimeElisionHints.enable": "skip_trivial",
    "rust-analyzer.inlayHints.parameterHints.enable": true,
    "rust-analyzer.inlayHints.typeHints.enable": true,
    "rust-analyzer.lens.enable": true,
    "rust-analyzer.lens.references.adt.enable": true,
    "rust-analyzer.lens.references.method.enable": true,
    "rust-analyzer.lens.run.enable": true,
    "rust-analyzer.lens.debug.enable": true,
    "rust-analyzer.lens.implementations.enable": true,
    "rust-analyzer.semanticHighlighting.operator.specialization.enable": true,
    "rust-analyzer.semanticHighlighting.punctuation.enable": true,
    "rust-analyzer.diagnostics.experimental.enable": true,
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                          🐹 GO                                           ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "[go]": {
        "editor.defaultFormatter": "golang.go",
        "editor.formatOnSave": false,
        "editor.tabSize": 4,
        "editor.insertSpaces": false,
        "editor.rulers": [
            80,
            120
        ],
        "editor.semanticHighlighting.enabled": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "always"
        }
    },
    "[go.mod]": {
        "editor.defaultFormatter": "golang.go",
        "editor.formatOnSave": false
    },
    "[go.sum]": {
        "editor.formatOnSave": false
    },
    // Go Extension (golang.go)
    "go.useLanguageServer": true,
    "go.languageServerFlags": [
        "-remote=auto"
    ],
    "go.buildOnSave": "workspace",
    "go.lintOnSave": "workspace",
    "go.vetOnSave": "workspace",
    "go.lintTool": "golangci-lint",
    "go.lintFlags": [
        "--fast"
    ],
    "go.formatTool": "goimports",
    "go.autocompleteUnimportedPackages": true,
    "go.addTags": {
        "tags": "json",
        "options": "json=omitempty",
        "promptForTags": false,
        "transform": "snakecase"
    },
    "go.testFlags": [
        "-v",
        "-race"
    ],
    "go.testOnSave": false,
    "go.coverOnSave": false,
    "go.coverageDecorator": {
        "type": "gutter",
        "coveredHighlightColor": "rgba(64,128,128,0.5)",
        "uncoveredHighlightColor": "rgba(128,64,64,0.25)",
        "coveredGutterStyle": "blockgreen",
        "uncoveredGutterStyle": "blockred"
    },
    "go.toolsManagement.autoUpdate": true,
    "go.survey.prompt": false,
    "go.inlayHints.assignVariableTypes": true,
    "go.inlayHints.compositeLiteralFields": true,
    "go.inlayHints.compositeLiteralTypes": true,
    "go.inlayHints.constantValues": true,
    "go.inlayHints.functionTypeParameters": true,
    "go.inlayHints.parameterNames": true,
    "go.inlayHints.rangeVariableTypes": true,
    "gopls": {
        "ui.completion.usePlaceholders": true,
        "ui.semanticTokens": true,
        "ui.codelenses": {
            "gc_details": true,
            "generate": true,
            "regenerate_cgo": true,
            "run_govulncheck": true,
            "test": true,
            "tidy": true,
            "upgrade_dependency": true,
            "vendor": true
        },
        "ui.diagnostic.analyses": {
            "fieldalignment": true,
            "nilness": true,
            "shadow": true,
            "unusedparams": true,
            "unusedwrite": true,
            "useany": true
        },
        "formatting.gofumpt": true
    },
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                      📄 OTHER LANGUAGES                                  ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.tabSize": 4,
        "editor.formatOnSave": false
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.tabSize": 4,
        "editor.formatOnSave": false
    },
    "[yaml]": {
        "editor.tabSize": 2,
        "editor.formatOnSave": false,
        "diffEditor.ignoreTrimWhitespace": true
    },
    "[markdown]": {
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        }
    },
    "[dockerfile]": {
        "editor.defaultFormatter": "ms-azuretools.vscode-containers"
    },
    "[shellscript]": {
        "editor.defaultFormatter": "shakram02.bash-beautify",
        "editor.formatOnSave": false,
        "editor.tabSize": 4
    },
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                           💻 TERMINAL                                    ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "terminal.integrated.fontFamily": "JetBrains Mono",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.enablePersistentSessions": true,
    // Platform-specific terminal profiles
    "terminal.integrated.profiles.windows": {
        "Git Bash": {
            "path": "C:/Users/NovosadOleh/AppData/Local/Programs/Git/bin/bash.exe"
        },
        "PowerShell": {
            "source": "PowerShell"
        },
        "Command Prompt": {
            "path": "cmd.exe"
        }
    },
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.profiles.linux": {
        "bash": {
            "path": "/bin/bash",
            "args": [
                "-l"
            ]
        },
        "zsh": {
            "path": "/usr/bin/zsh",
            "args": [
                "-l"
            ]
        }
    },
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.profiles.osx": {
        "zsh": {
            "path": "/bin/zsh",
            "args": [
                "-l"
            ]
        },
        "bash": {
            "path": "/bin/bash",
            "args": [
                "-l"
            ]
        }
    },
    "terminal.integrated.defaultProfile.osx": "zsh",
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                          🌐 GIT & VERSION CONTROL                        ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "git.suggestSmartCommit": false,
    "git.confirmSync": false,
    "git.openRepositoryInParentFolders": "always",
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.renderSideBySide": true,
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                         🤖 AI & GITHUB COPILOT                           ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                         🔗 REMOTE & SSH                                  ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "remote.SSH.remotePlatform": {
    },
    "remote.SSH.connectTimeout": 60,
    // ╔══════════════════════════════════════════════════════════════════════════╗
    // ║                      🔒 SECURITY & PRIVACY                               ║
    // ╚══════════════════════════════════════════════════════════════════════════╝
    "telemetry.telemetryLevel": "off",
    "security.workspace.trust.untrustedFiles": "open",
    "extensions.autoCheckUpdates": true,
    "extensions.autoUpdate": true,
    "update.mode": "start",
    "workbench.colorTheme": "Visual Studio Dark - C++"
}
